{
  "name": "saraha",
  "version": "1.0.0",
  "scripts": {
    "serve:backend": "nx serve backend",
    "serve:frontend": "nx serve frontend",
    "serve": "nx run-many -t serve -p backend frontend --parallel",
    "build:backend": "nx build backend",
    "build:frontend": "nx build frontend",
    "build": "nx run-many -t build --all",
    "test": "nx run-many -t test --all",
    "lint": "nx run-many -t lint --all",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node --project tsconfig.json -e \"require('ts-node/register')\" prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Saraha – anonymous message platform (NestJS + React + PostgreSQL)",
  "prisma": {
    "seed": "pnpm run prisma:seed"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "5.22.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/devkit": "22.6.5",
    "@nx/esbuild": "^22.6.5",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/jest": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/nest": "22.6.5",
    "@nx/node": "22.6.5",
    "@nx/playwright": "22.6.5",
    "@nx/react": "22.6.5",
    "@nx/vite": "22.6.5",
    "@nx/web": "22.6.5",
    "@nx/webpack": "22.6.5",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.26",
    "@swc/helpers": "~0.5.18",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/ui": "~4.1.0",
    "esbuild": "^0.28.0",
    "eslint": "~8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^29.0.0",
    "jest-environment-node": "^29.7.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "node-fetch": "^3.3.2",
    "nx": "22.6.5",
    "prettier": "~3.6.2",
    "prisma": "5.22.0",
    "swc-loader": "^0.2.7",
    "ts-jest": "^29.0.0",
    "ts-node": "10.9.1",
    "typescript": "~5.9.2",
    "vite": "^8.0.0",
    "vitest": "~4.1.0",
    "webpack-cli": "^5.1.4"
  },
  "nx": {},
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "node-fetch"
      ],
      "allowedVersions": {
        "node-fetch": "*"
      }
    }
  }
}
